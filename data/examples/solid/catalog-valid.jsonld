{
  "@context": {
    "dcat": "http://www.w3.org/ns/dcat#",
    "dct": "http://purl.org/dc/terms/"
  },
  "@id": "https://example.org/catalogs/solid-jsonld",
  "@type": "dcat:Catalog",
  "dct:title": "Solid JSON-LD handover catalog",
  "dcat:contactPoint": {
    "@id": "https://example.org/profile/card#me"
  },
  "dcat:dataset": {
    "@id": "https://example.org/datasets/water-quality",
    "@type": "dcat:Dataset",
    "dct:title": "Water quality observations",
    "dcat:contactPoint": {
      "@id": "https://example.org/profile/card#me"
    },
    "dcat:distribution": {
      "@id": "https://example.org/datasets/water-quality/distribution",
      "@type": "dcat:Distribution",
      "dcat:downloadURL": {
        "@id": "https://example.org/data/water-quality.csv"
      },
      "dcat:mediaType": "text/csv"
    }
  }
}

