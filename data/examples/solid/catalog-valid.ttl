@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dct: <http://purl.org/dc/terms/> .

<https://example.org/catalogs/solid-ttl> a dcat:Catalog ;
    dct:title "Solid handover catalog" ;
    dcat:contactPoint <https://example.org/profile/card#me> ;
    dcat:dataset <https://example.org/datasets/air-quality> .

<https://example.org/datasets/air-quality> a dcat:Dataset ;
    dct:title "Air quality observations" ;
    dcat:contactPoint <https://example.org/profile/card#me> ;
    dcat:distribution <https://example.org/datasets/air-quality/distribution> .

<https://example.org/datasets/air-quality/distribution> a dcat:Distribution ;
    dcat:downloadURL <https://example.org/data/air-quality.csv> ;
    dcat:mediaType "text/csv" .

